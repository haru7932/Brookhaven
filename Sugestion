-- (Mantive sua lógica de Draggable e Entrance aqui de forma simplificada)
local function makeDraggable()
    local dragging, dragStart, startPos
    Header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = Frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            Shadow.Position = UDim2.new(Frame.Position.X.Scale, Frame.Position.X.Offset - 2, Frame.Position.Y.Scale, Frame.Position.Y.Offset + 2)
        end
    end)
end

coroutine.wrap(makeDraggable)()
