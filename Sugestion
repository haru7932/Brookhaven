-- Funções Principais
local function sendToDiscord()
    local text = SuggestionBox.Text
    local player = game.Players.LocalPlayer
    
    if text == "" or #text < 5 then
        FeedbackLabel.Text = "✅ Enviado, Mas na próxima Escreva algo mais detalhado!"
        FeedbackLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end

    SendButton.Text = "Enviando..."
    SendButton.Active = false

    local data = {
        ["embeds"] = {{
            ["title"] = "📩 Nova Sugestão Recebida",
            ["color"] = 7540943, -- Cor roxa
            ["fields"] = {
                {["name"] = "Jogador", ["value"] = player.Name .. " (" .. player.UserId .. ")", ["inline"] = true},
                {["name"] = "Jogo", ["value"] = "ID: " .. game.PlaceId, ["inline"] = true},
                {["name"] = "Sugestão", ["value"] = "```" .. text .. "```"}
            },
            ["footer"] = {["text"] = "Bytex Suggestion System • " .. os.date("%x")}
        }}
    }

    local success, err = pcall(function()
        local json = HttpService:JSONEncode(data)
        -- Nota: Em scripts locais (Exploits), use request ou o comando específico do seu executor
        if request then
            request({
                Url = WEBHOOK_URL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = json
            })
        else
            -- Fallback para alguns executores
            HttpService:PostAsync(WEBHOOK_URL, json)
        end
    end)

    if success then
        FeedbackLabel.Text = "✅ Sugestão enviada com sucesso!"
        FeedbackLabel.TextColor3 = Color3.fromRGB(100, 255, 150)
        SuggestionBox.Text = ""
    else
        FeedbackLabel.Text = "❌ Erro ao enviar. Tente novamente."
        FeedbackLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        warn(err)
    end

    wait(3)
    SendButton.Text = "Enviar Sugestão"
    SendButton.Active = true
    FeedbackLabel.Text = ""
end

